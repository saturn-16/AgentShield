*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
*.whl
.Python
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
.venv/
venv/
env/
ENV/

# ── Node.js ──────────────────────────────────────────────────
node_modules/
.next/
out/
.nuxt/
dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Environment ──────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── IDE / Editor ─────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/
*.sublime-workspace
*.sublime-project

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ── Database ─────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
postgres_data/
redis_data/

# ── Testing ──────────────────────────────────────────────────
.coverage
htmlcov/
coverage/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Docker ───────────────────────────────────────────────────
docker-compose.override.yml

# ── Misc ─────────────────────────────────────────────────────
*.log
*.bak
*.tmp
.cache/

.vercel
