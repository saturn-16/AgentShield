# ============================================================
# AgentShield AI — Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# ============================================================

# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string (asyncpg driver for async support)
DATABASE_URL=postgresql+asyncpg://agentshield:agentshield_dev@postgres:5432/agentshield
# Password used by the postgres container on first init
DB_PASSWORD=agentshield_dev

# ── Redis ────────────────────────────────────────────────────
# Redis connection for caching, sessions, and rate-limiting
REDIS_URL=redis://redis:6379/0

# ── Security / JWT ───────────────────────────────────────────
# HMAC secret for signing JWTs — generate a strong random value in prod
SECRET_KEY=your-secret-key-change-in-production
# JWT signing algorithm
ALGORITHM=HS256
# Access token lifetime (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Refresh token lifetime (days)
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ─────────────────────────────────────────────────────
# JSON array of allowed origins (use specific domains in production)
CORS_ORIGINS=["http://localhost:3000"]

# ── Celery ───────────────────────────────────────────────────
# Broker URL — uses a separate Redis DB to isolate from cache
CELERY_BROKER_URL=redis://redis:6379/1

# ── AI / LLM Providers ──────────────────────────────────────
# OpenAI API key (optional — agents fall back to rule-based analysis)
OPENAI_API_KEY=

# ── Application ─────────────────────────────────────────────
APP_NAME=AgentShield AI
# Enable debug mode (set to false in production)
DEBUG=true
# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ── Frontend ─────────────────────────────────────────────────
# Public API URL exposed to the browser
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
